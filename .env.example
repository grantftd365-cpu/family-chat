# FamilyChat v2.0 配置

# LLM 配置（必填）
LLM_PROVIDER=deepseek          # 支持: openai, deepseek, zhipu, qwen, local
LLM_API_KEY=your-api-key-here  # 你的 API Key
LLM_MODEL=deepseek-chat        # 模型名称
LLM_BASE_URL=                  # 自定义 Base URL（留空用默认）
LLM_TEMPERATURE=0.8            # 温度 0-1

# 安全配置
SECRET_KEY=change-this-to-a-random-string

# 可选
# DEEPSEEK_API_KEY=            # 兼容旧配置
