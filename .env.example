# ============================================================
# FamilyChat 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# === LLM 配置 ===
# 支持的 provider: openai / deepseek / zhipu / qwen / local
# LLM_API_KEY 必须填写完整真实 Key，不要填写 sk-xxxx*** 这类脱敏显示值
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=
LLM_TEMPERATURE=0.8

# === 安全配置（必填） ===
# ⚠️ 必须设置！未设置时服务拒绝启动
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# CORS 允许的域名（逗号分隔），未设置时仅允许 localhost
# 生产环境必须设置为实际域名，例如:
# CORS_ORIGINS=https://chat.yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=

# === 服务器配置 ===
HOST=0.0.0.0
PORT=8000

# === 微信登录（可选） ===
# 在微信公众平台/开放平台获取
WX_APPID=
WX_SECRET=
# OAuth scope: snsapi_base（仅 openid）或 snsapi_userinfo（获取用户信息）
WX_OAUTH_SCOPE=snsapi_userinfo

# === 时区 ===
TZ=Asia/Shanghai
