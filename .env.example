# ============================================================
# FamilyChat 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# === LLM 配置 ===
# 支持的 provider: openai / deepseek / zhipu / qwen / local
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=
LLM_TEMPERATURE=0.8

# === 安全配置 ===
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# === 服务器配置 ===
HOST=0.0.0.0
PORT=8000

# === 微信小程序登录（可选） ===
# 在微信公众平台获取
WX_APPID=
WX_SECRET=

# === 时区 ===
TZ=Asia/Shanghai
