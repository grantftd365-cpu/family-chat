<!--pages/chat/chat.wxml - 聊天室-->
<view class="container" style="padding-top: {{statusBarHeight}}px;">
  <!-- 消息列表 -->
  <scroll-view
    scroll-y
    class="msg-list"
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
      <!-- 系统消息 -->
      <view wx:if="{{item.msg_type === 'system'}}" class="sys-msg">
        <text class="sys-text">{{item.content}}</text>
      </view>

      <!-- 普通消息 -->
      <view wx:else class="msg-row {{item.isMine ? 'self' : 'other'}}">
        <view class="msg-avatar">
          <text>{{item.sender_avatar || '😀'}}</text>
        </view>
        <view class="msg-main">
          <view wx:if="{{!item.isMine}}" class="msg-sender">{{item.sender_name}}</view>
          <!-- 回复引用 -->
          <view wx:if="{{item.reply_content}}" class="msg-reply-quote">
            <text>{{item.reply_content}}</text>
          </view>
          <!-- 气泡 -->
          <view class="msg-bubble" bindlongpress="onLongPress" data-id="{{item.id}}" data-sender="{{item.sender_id}}" data-content="{{item.content}}">
            <text wx:if="{{item.msg_type === 'text'}}" class="msg-text" user-select>{{item.content}}</text>
            <image wx:elif="{{item.msg_type === 'image'}}" src="{{item.media_url || item.content}}" mode="widthFix" class="msg-image" bindtap="previewImage" data-url="{{item.media_url || item.content}}" />
            <view wx:elif="{{item.msg_type === 'red_envelope'}}" class="msg-red-packet">
              <view class="red-packet-icon">🧧</view>
              <view class="red-packet-text">{{item.content}}</view>
            </view>
            <view wx:elif="{{item.msg_type === 'voice'}}" class="msg-voice-bubble">
              <text>🎤 语音消息</text>
            </view>
            <view wx:elif="{{item.msg_type === 'file'}}" class="msg-file-bubble">
              <text>📎 {{item.file_name || '文件'}}</text>
            </view>
            <text wx:else class="msg-text" user-select>{{item.content}}</text>
          </view>
          <!-- Reactions -->
          <view wx:if="{{item.reactions.length > 0}}" class="msg-reactions">
            <text wx:for="{{item.reactions}}" wx:key="emoji" wx:for-item="r" class="reaction-tag">{{r.emoji}}</text>
          </view>
          <view class="msg-meta">
            <text class="msg-time">{{item.timeStr}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 正在输入 -->
    <view wx:if="{{typingAgent}}" class="typing-bar">
      <view class="typing-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
      <text class="typing-text">{{typingAgent}} 正在输入</text>
    </view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar safe-bottom">
    <view class="input-actions">
      <view class="action-btn" bindtap="toggleMore">
        <text>＋</text>
      </view>
    </view>
    <view class="input-wrap">
      <textarea
        class="msg-input"
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        confirm-type="send"
        placeholder="输入消息..."
        auto-height
        maxlength="500"
        cursor-spacing="20"
      />
    </view>
    <view class="input-actions">
      <view class="action-btn" bindtap="toggleEmoji">
        <text>😊</text>
      </view>
    </view>
    <button
      wx:if="{{inputText}}"
      class="send-btn"
      bindtap="sendMessage"
    >
      发送
    </button>
  </view>

  <!-- 更多面板 -->
  <view wx:if="{{showMore}}" class="more-panel safe-bottom">
    <view class="more-grid">
      <view class="more-item" bindtap="chooseImage">
        <view class="more-icon">📷</view>
        <text class="more-label">照片</text>
      </view>
      <view class="more-item" bindtap="takePhoto">
        <view class="more-icon">📸</view>
        <text class="more-label">拍摄</text>
      </view>
      <view class="more-item" bindtap="sendRedEnvelope">
        <view class="more-icon">🧧</view>
        <text class="more-label">红包</text>
      </view>
      <view class="more-item" bindtap="inviteMember">
        <view class="more-icon">👥</view>
        <text class="more-label">邀请</text>
      </view>
    </view>
  </view>
</view>
