/* pages/chat/chat.wxss */
.msg-list {
  flex: 1;
  height: 0;
  padding: 16rpx 24rpx;
  background: var(--bg);
}

/* 系统消息 */
.sys-msg {
  text-align: center;
  padding: 16rpx 0;
}
.sys-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: rgba(0, 0, 0, 0.04);
  padding: 6rpx 24rpx;
  border-radius: var(--radius-full);
}

/* 消息行 */
.msg-row {
  display: flex;
  margin-bottom: 28rpx;
  align-items: flex-start;
}
.msg-row.self {
  flex-direction: row-reverse;
}
.msg-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  font-size: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-white);
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}
.msg-main {
  max-width: 65%;
  margin: 0 16rpx;
}
.msg-row.self .msg-main {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
}
.msg-sender {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 6rpx;
  padding-left: 4rpx;
}
.msg-reply-quote {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: rgba(0, 0, 0, 0.04);
  padding: 10rpx 16rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 8rpx;
  border-left: 4rpx solid var(--primary);
}

/* 气泡 */
.msg-bubble {
  padding: 20rpx 28rpx;
  border-radius: var(--radius-lg);
  background: var(--bubble-other);
  word-break: break-all;
  position: relative;
  box-shadow: var(--shadow-sm);
}
.msg-row.self .msg-bubble {
  background: var(--bubble-self);
}
/* 气泡箭头 */
.msg-bubble::before {
  content: '';
  position: absolute;
  top: 24rpx;
  border: 10rpx solid transparent;
}
.msg-row.other .msg-bubble::before {
  left: -18rpx;
  border-right-color: var(--bubble-other);
}
.msg-row.self .msg-bubble::before {
  right: -18rpx;
  border-left-color: var(--bubble-self);
}

.msg-text {
  font-size: 30rpx;
  line-height: 1.6;
}
.msg-image {
  max-width: 400rpx;
  min-width: 120rpx;
  border-radius: var(--radius-sm);
}
.msg-red-packet {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #FA5151, #FF6B6B) !important;
  color: #fff;
  padding: 28rpx;
  border-radius: var(--radius-lg);
}
.msg-red-packet::before {
  display: none;
}
.red-packet-icon {
  font-size: 52rpx;
}
.red-packet-text {
  font-size: 28rpx;
  font-weight: 500;
}
.msg-voice-bubble {
  min-width: 120rpx;
}
.msg-file-bubble {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* Reactions */
.msg-reactions {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}
.reaction-tag {
  background: rgba(0, 0, 0, 0.05);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
}

.msg-meta {
  margin-top: 6rpx;
  padding: 0 4rpx;
}
.msg-time {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

/* 正在输入 */
.typing-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
}
.typing-dots {
  display: flex;
  gap: 6rpx;
}
.typing-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--text-tertiary);
  animation: typingBounce 1.4s ease-in-out infinite;
}
.typing-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dots .dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-8rpx); opacity: 1; }
}
.typing-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: flex-end;
  padding: 16rpx 20rpx;
  background: var(--bg);
  border-top: 0.5rpx solid var(--border-light);
  gap: 12rpx;
}
.input-actions {
  flex-shrink: 0;
  padding-bottom: 12rpx;
}
.action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: var(--shadow-sm);
}
.action-btn:active {
  background: var(--bg-hover);
}
.input-wrap {
  flex: 1;
  min-width: 0;
}
.msg-input {
  width: 100%;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 16rpx 24rpx;
  font-size: 30rpx;
  max-height: 200rpx;
  min-height: 64rpx;
  line-height: 1.5;
  box-shadow: var(--shadow-sm);
}
.send-btn {
  background: var(--primary-gradient);
  color: #fff;
  border: none;
  border-radius: var(--radius-lg);
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}
.send-btn::after {
  border: none;
}
.send-btn:active {
  opacity: 0.9;
}

/* 更多面板 */
.more-panel {
  background: var(--bg);
  border-top: 0.5rpx solid var(--border-light);
  padding: 32rpx;
}
.more-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx;
}
.more-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.more-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: var(--shadow-sm);
}
.more-icon:active {
  background: var(--bg-hover);
}
.more-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}
