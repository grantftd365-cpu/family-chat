<!--pages/index/index.wxml - 消息列表-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-box" bindtap="goSearch">
      <text class="icon">🔍</text>
      <text>搜索</text>
    </view>
  </view>

  <!-- 群聊列表 -->
  <scroll-view scroll-y class="chat-list" enhanced show-scrollbar="{{false}}" refresher-enabled bindrefresherrefresh="onRefresh" refresher-triggered="{{refreshing}}">
    <view
      wx:for="{{groups}}"
      wx:key="id"
      class="cell"
      bindtap="goChat"
      data-id="{{item.id}}"
      data-name="{{item.name}}"
    >
      <view class="icon">
        <text>{{item.avatar || '👥'}}</text>
      </view>
      <view class="content">
        <view class="label">{{item.name}}</view>
        <view class="desc">{{item.last_message || '暂无消息'}}</view>
      </view>
      <view class="extra">
        <view class="time">{{item.timeStr}}</view>
        <view wx:if="{{item.unread}}" class="badge">{{item.unread > 99 ? '99+' : item.unread}}</view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && groups.length === 0}}" class="empty">
      <view class="emoji">💬</view>
      <view class="title">还没有聊天</view>
      <view class="subtitle">邀请家人加入，开始畅聊</view>
    </view>
  </scroll-view>

  <!-- 未登录遮罩 -->
  <view wx:if="{{!isLoggedIn}}" class="login-mask">
    <view class="login-card">
      <view class="login-logo">🏠</view>
      <view class="login-title">FamilyChat</view>
      <view class="login-desc">家庭数字人聊天</view>
      <button class="btn btn-primary btn-block" bindtap="goLogin">
        开始使用
      </button>
    </view>
  </view>
</view>
