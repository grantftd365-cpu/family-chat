/* pages/index/index.wxss */
.chat-list {
  flex: 1;
  height: 0;
}

.login-mask {
  position: fixed;
  inset: 0;
  background: var(--bg-mask);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(8px);
}
.login-card {
  background: var(--bg-white);
  border-radius: var(--radius-xl);
  padding: 64rpx 48rpx;
  text-align: center;
  width: 80%;
  max-width: 600rpx;
  box-shadow: var(--shadow-lg);
}
.login-logo {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}
.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.login-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}
