/* pages/contacts/contacts.wxss */
.section {
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 26rpx;
  color: var(--text-sub);
  padding: 16rpx 32rpx 8rpx;
  background: var(--bg);
}
.online-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--green);
}
.badge {
  background: var(--danger);
  color: #fff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}
