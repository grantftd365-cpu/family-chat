/* pages/join/join.wxss */
.join-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx 48rpx;
}
.join-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
.join-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.join-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.code-section {
  padding: 0 48rpx;
  margin-bottom: 32rpx;
}
.code-inputs {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}
.code-cell {
  width: 80rpx;
  height: 96rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-transform: uppercase;
  transition: all 0.2s;
}
.code-cell.filled {
  background: var(--primary-light);
  border: 2rpx solid var(--primary);
}

.preview-card {
  display: flex;
  align-items: center;
  background: var(--bg-white);
  margin: 0 48rpx 48rpx;
  padding: 32rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}
.preview-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  background: var(--bg);
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.preview-info {
  margin-left: 24rpx;
}
.preview-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.preview-count {
  font-size: 26rpx;
  color: var(--primary);
  margin-top: 4rpx;
}

.join-actions {
  padding: 32rpx 48rpx;
}
