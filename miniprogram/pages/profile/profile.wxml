<!--pages/profile/profile.wxml - 个人中心-->
<view class="container">
  <!-- 用户信息卡 -->
  <view class="profile-card" wx:if="{{user}}">
    <view class="profile-header">
      <view class="avatar avatar-xl">
        <text>{{user.avatar || '😀'}}</text>
      </view>
      <view class="profile-info">
        <view class="profile-name">{{user.nickname}}</view>
        <view class="profile-id">ID: {{user.id}}</view>
      </view>
    </view>
    <view class="profile-signature" wx:if="{{user.signature}}">
      {{user.signature}}
    </view>
  </view>

  <!-- 未登录 -->
  <view class="profile-card" wx:else>
    <view class="profile-header">
      <view class="avatar avatar-xl">
        <text>😀</text>
      </view>
      <view class="profile-info">
        <button class="btn btn-primary btn-sm" bindtap="goLogin">登录</button>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="section">
    <view class="cell" bindtap="goMyAgent">
      <view class="icon" style="background: #E3F2FD;">🤖</view>
      <view class="content">
        <view class="label">我的数字人</view>
        <view class="desc">训练你的数字分身</view>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="cell" bindtap="goMoments">
      <view class="icon" style="background: #FCE4EC;">📷</view>
      <view class="content">
        <view class="label">朋友圈</view>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="cell" bindtap="goFavorites">
      <view class="icon" style="background: #FFF8E1;">⭐</view>
      <view class="content">
        <view class="label">我的收藏</view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="section">
    <view class="cell" bindtap="goInvite">
      <view class="icon" style="background: #E8F5E9;">👨‍👩‍👧‍👦</view>
      <view class="content">
        <view class="label">邀请家人</view>
        <view class="desc">分享邀请码给家人</view>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="cell" bindtap="goSettings">
      <view class="icon" style="background: #F5F5F5;">⚙️</view>
      <view class="content">
        <view class="label">设置</view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="version-text">FamilyChat v2.0</view>
</view>
