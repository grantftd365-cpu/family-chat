<!--pages/profile/profile.wxml - 个人中心-->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <view class="user-avatar">{{user.avatar || '😀'}}</view>
    <view class="user-info" wx:if="{{user}}">
      <view class="user-name">{{user.nickname}}</view>
      <view class="user-id">ID: {{user.id}}</view>
    </view>
    <view class="user-info" wx:else>
      <button class="btn-primary" bindtap="doLogin">微信登录</button>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="section">
    <view class="list-item" bindtap="goMyAgent">
      <view class="avatar">🤖</view>
      <view class="info">
        <view class="name">我的数字人</view>
        <view class="desc">查看和训练你的数字分身</view>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="list-item" bindtap="goFavorites">
      <view class="avatar">⭐</view>
      <view class="info">
        <view class="name">我的收藏</view>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="list-item" bindtap="goMoments">
      <view class="avatar">📷</view>
      <view class="info">
        <view class="name">朋友圈</view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="section">
    <view class="list-item" bindtap="goSettings">
      <view class="avatar">⚙️</view>
      <view class="info">
        <view class="name">设置</view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version">FamilyChat v2.0 小程序版</view>
</view>
