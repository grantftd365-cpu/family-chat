/* pages/profile/profile.wxss */
.profile-card {
  background: var(--bg-white);
  margin: 24rpx 32rpx;
  padding: 40rpx 32rpx;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
}
.profile-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.profile-info {
  flex: 1;
}
.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.profile-id {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.profile-signature {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  padding-top: 20rpx;
  border-top: 0.5rpx solid var(--border-light);
}

.version-text {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-placeholder);
  padding: 48rpx 0;
}
