/**
 * FamilyChat 设计系统 v2.0
 * 对标微信高端小程序 UI 规范
 */

/* ========== 设计令牌 ========== */
page {
  /* 品牌色 */
  --primary: #07C160;
  --primary-dark: #06AD56;
  --primary-light: #E8F8EE;
  --primary-gradient: linear-gradient(135deg, #07C160 0%, #06AD56 100%);

  /* 中性色 */
  --bg: #F6F6F6;
  --bg-white: #FFFFFF;
  --bg-hover: #F0F0F0;
  --bg-mask: rgba(0, 0, 0, 0.5);
  --card: #FFFFFF;

  /* 文字色 */
  --text-primary: #1A1A1A;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --text-placeholder: #C0C0C0;
  --text-inverse: #FFFFFF;

  /* 边框 */
  --border: #E8E8E8;
  --border-light: #F0F0F0;

  /* 功能色 */
  --danger: #FA5151;
  --warning: #FF9C00;
  --success: #07C160;
  --info: #10AEFF;

  /* 聊天气泡 */
  --bubble-self: #95EC69;
  --bubble-other: #FFFFFF;
  --bubble-system: #F0F0F0;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);

  /* 圆角 */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 999rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* 字体 */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-primary);
  background: var(--bg);
  -webkit-font-smoothing: antialiased;
}

/* ========== 布局 ========== */
.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 100vh;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ========== 头部栏 ========== */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  height: 88rpx;
  background: var(--bg-white);
  border-bottom: 0.5rpx solid var(--border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-bar .title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.nav-bar .back {
  font-size: 40rpx;
  color: var(--text-primary);
  padding: 16rpx;
  margin-left: -16rpx;
}

/* ========== 列表项 ========== */
.cell {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: var(--bg-white);
  position: relative;
}
.cell:active {
  background: var(--bg-hover);
}
.cell::after {
  content: '';
  position: absolute;
  left: 112rpx;
  right: 0;
  bottom: 0;
  height: 0.5rpx;
  background: var(--border-light);
}
.cell:last-child::after {
  display: none;
}
.cell .icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
  overflow: hidden;
}
.cell .icon image {
  width: 100%;
  height: 100%;
}
.cell .content {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}
.cell .label {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cell .desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cell .extra {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
  flex-shrink: 0;
}
.cell .time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.cell .badge {
  background: var(--danger);
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  margin-top: 8rpx;
}
.cell .arrow {
  font-size: 32rpx;
  color: var(--text-placeholder);
  margin-left: 12rpx;
}

/* ========== 搜索栏 ========== */
.search-bar {
  padding: 16rpx 32rpx;
  background: var(--bg);
}
.search-box {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  background: var(--bg-white);
  border-radius: var(--radius-full);
  font-size: 28rpx;
  color: var(--text-placeholder);
  gap: 12rpx;
  box-shadow: var(--shadow-sm);
}
.search-box .icon {
  font-size: 32rpx;
}

/* ========== 按钮 ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  letter-spacing: 2rpx;
}
.btn::after {
  border: none;
}
.btn-primary {
  background: var(--primary-gradient);
  color: var(--text-inverse);
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}
.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}
.btn-secondary {
  background: var(--bg-white);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}
.btn-block {
  width: 100%;
}
.btn-sm {
  height: 72rpx;
  font-size: 28rpx;
  border-radius: var(--radius-md);
}
.btn-round {
  border-radius: var(--radius-full);
}

/* ========== 头像 ========== */
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  background: var(--bg);
  flex-shrink: 0;
  overflow: hidden;
}
.avatar image {
  width: 100%;
  height: 100%;
}
.avatar-sm {
  width: 72rpx;
  height: 72rpx;
  font-size: 40rpx;
}
.avatar-lg {
  width: 128rpx;
  height: 128rpx;
  font-size: 72rpx;
  border-radius: var(--radius-lg);
}
.avatar-xl {
  width: 176rpx;
  height: 176rpx;
  font-size: 96rpx;
  border-radius: var(--radius-xl);
}

/* ========== 区块 ========== */
.section {
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-tertiary);
  padding: 24rpx 32rpx 12rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}
.empty .emoji {
  font-size: 128rpx;
  margin-bottom: 32rpx;
}
.empty .title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.empty .subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ========== 卡片 ========== */
.card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  margin: 24rpx 32rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

/* ========== 分割线 ========== */
.divider {
  height: 0.5rpx;
  background: var(--border-light);
  margin: 0 32rpx;
}

/* ========== 徽标 ========== */
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--danger);
  flex-shrink: 0;
}
.dot-online {
  background: var(--success);
}

/* ========== 加载 ========== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}
.loading-wrap text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-left: 12rpx;
}
